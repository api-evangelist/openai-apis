                  "type": "text",
                  "description": "The model to use for image editing"
                },
                {
                  "key": "n",
                  "value": "1",
                  "type": "text",
                  "description": "The number of images to generate"
                },
                {
                  "key": "size",
                  "value": "1024x1024",
                  "type": "text",
                  "description": "The size of the generated images (This can only be one of 256x256,512x512,1024x1024)"
                },
                {
                  "key": "response_format",
                  "value": "url",
                  "type": "text",
                  "description": "The format in which the generated images are returned (This can only be one of url,b64_json)"
                },
                {
                  "key": "user",
                  "value": "<string>",
                  "type": "text",
                  "description": "A unique identifier representing your end-user"
                }
              ]
