{
  "opencollection": "1.0.0",
  "info": {
    "name": "OpenAI APIs OpenAI Audio API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Speech",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "OpenAI APIs Create speech",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.openai.com/v1/audio/speech",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Generates audio from the input text using the specified voice and model."
        }
      ]
    },
    {
      "info": {
        "name": "Transcription",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "OpenAI APIs Create transcription",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.openai.com/v1/audio/transcriptions",
            "body": {
              "type": "multipart-form",
              "data": []
            }
          },
          "docs": "Transcribes audio into the input language as text using the Whisper model."
        }
      ]
    },
    {
      "info": {
        "name": "Translation",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "OpenAI APIs Create translation",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.openai.com/v1/audio/translations",
            "body": {
              "type": "multipart-form",
              "data": []
            }
          },
          "docs": "Translates audio into English text using the Whisper model."
        }
      ]
    }
  ],
  "bundled": true
}